# ============================================
# EXPERIMENT 5
# Morphology using Add-Delete Table
# ============================================

# ============================================
# FUNCTION FOR MORPHOLOGICAL ANALYSIS
# ============================================

def morphology_analysis(root_word, modified_word):

    print("\n===================================")
    print("MORPHOLOGICAL ANALYSIS")
    print("===================================\n")

    print("Root Word      :", root_word)
    print("Modified Word  :", modified_word)

    # ============================================
    # FIND COMMON PREFIX
    # ============================================

    common = ""

    for i in range(min(len(root_word), len(modified_word))):

        if root_word[i] == modified_word[i]:
            common += root_word[i]

        else:
            break

    # ============================================
    # FIND DELETE PART
    # ============================================

    delete_part = root_word[len(common):]

    if delete_part == "":
        delete_part = "NULL"

    # ============================================
    # FIND ADD PART
    # ============================================

    add_part = modified_word[len(common):]

    if add_part == "":
        add_part = "NULL"

    # ============================================
    # DISPLAY RESULTS
    # ============================================

    print("\nCommon Root :", common)

    print("\n===================================")
    print("ADD-DELETE TABLE")
    print("===================================\n")

    print("{:<15} {:<15}".format("DELETE", "ADD"))
    print("{:<15} {:<15}".format(delete_part, add_part))


# ============================================
# EXAMPLE 1
# ============================================

morphology_analysis("play", "playing")

# ============================================
# EXAMPLE 2
# ============================================

morphology_analysis("walk", "walked")

# ============================================
# EXAMPLE 3
# ============================================

morphology_analysis("city", "cities")

# ============================================
# EXAMPLE 4
# ============================================

morphology_analysis("happy", "unhappy")

# ============================================
# EXAMPLE 5
# ============================================

morphology_analysis("write", "rewriting")

# ============================================
# CONCLUSION
# ============================================

print("\n===================================")
print("CONCLUSION")
print("===================================\n")

print("Successfully studied morphology")
print("using Add-Delete table approach.")